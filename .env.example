# Gumball Configuration
# Copy this file to .env and customize as needed

# Image version (for production docker-compose.prod.yml)
VERSION=latest

# Domain suffix for capsule URLs
# For local development:
DOMAIN_SUFFIX=localhost

# For production with real domain:
# DOMAIN_SUFFIX=your-domain.com

# NPM token for private GitHub packages (required for Web UI build)
# Get from: https://github.com/settings/tokens
NPM_TOKEN=ghp_xxx
