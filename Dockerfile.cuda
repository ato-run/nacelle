# Capsuled Engine - CUDA-enabled Dockerfile
# For GPU inference on Linux with NVIDIA GPUs
#
# NOTE: This file is not built by the default CI workflow.
# It is intended for GPU environments and may require a wider build context.
# If you need the legacy conversion library `../libadep`, build from repo root instead:
#   docker build -f engine/Dockerfile.cuda -t capsuled-engine:cuda .
# Run:   docker run --gpus all -p 4500:4500 -p 8000:8000 capsuled-engine:cuda

# ============================================
# Stage 1: Build Stage (Rust with CUDA)
# ============================================
FROM nvidia/cuda:12.4-devel-ubuntu22.04 AS builder

# Install Rust and build dependencies
RUN apt-get update && apt-get install -y \
    curl \
    pkg-config \
    libssl-dev \
    protobuf-compiler \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Install Rust
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
ENV PATH="/root/.cargo/bin:${PATH}"

WORKDIR /app

# Copy workspace files
COPY Cargo.toml Cargo.lock ./
COPY build.rs ./
COPY src ./src
COPY migrations ./migrations

# Copy legacy conversion library (if present)
COPY ../libadep /libadep

# NOTE: Docker cannot `COPY` from outside the build context.
# If this step fails, it means the build context is too narrow (common when running from engine/).

# Build release binary with CUDA support
RUN cargo build --release --bin capsuled-engine

# ============================================
# Stage 2: Runtime Stage with vLLM
# ============================================
FROM nvidia/cuda:12.4-runtime-ubuntu22.04 AS runtime

# Install Python and runtime dependencies
RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    python3-venv \
    ca-certificates \
    libssl3 \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install vLLM and PyTorch
RUN pip3 install --no-cache-dir \
    vllm \
    torch \
    transformers \
    huggingface_hub

# Create non-root user
RUN groupadd -r capsuled && useradd -r -g capsuled capsuled

# Create necessary directories
RUN mkdir -p /var/lib/capsuled /var/log/capsuled /tmp/capsuled /models \
    && chown -R capsuled:capsuled /var/lib/capsuled /var/log/capsuled /tmp/capsuled /models

# Copy binary from builder
COPY --from=builder /app/target/release/capsuled-engine /usr/local/bin/

# Copy migrations
COPY --from=builder /app/migrations /var/lib/capsuled/migrations

# Copy GPU check script
COPY scripts/check-gpu.sh /usr/local/bin/
RUN chmod +x /usr/local/bin/check-gpu.sh

# Set environment
ENV RUST_LOG=info
ENV CAPSULED_DATA_DIR=/var/lib/capsuled
ENV CAPSULED_LOG_DIR=/var/log/capsuled
ENV NVIDIA_VISIBLE_DEVICES=all
ENV NVIDIA_DRIVER_CAPABILITIES=compute,utility
ENV HF_HOME=/models/huggingface

# Expose ports
# 4500: Capsuled Engine HTTP API
# 8000: vLLM OpenAI-compatible API
EXPOSE 4500 8000

# Health check for Engine
HEALTHCHECK --interval=30s --timeout=5s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:4500/health || exit 1

# Default: run both Engine and vLLM (via supervisord or separate containers)
ENTRYPOINT ["capsuled-engine"]
CMD ["--port", "4500", "--gpu-enabled"]
