#!/usr/bin/env bash
set -euo pipefail

remote_name="${1:-}"
remote_url="${2:-}"

run_checks=false

# pre-push receives lines: <local ref> <local sha> <remote ref> <remote sha>
while read -r local_ref local_sha remote_ref remote_sha; do
  # Block direct pushes to main unless local CI passes.
  if [[ "$remote_ref" == "refs/heads/main" ]]; then
    run_checks=true
  fi
done

if [[ "$run_checks" != "true" ]]; then
  exit 0
fi

echo "[pre-push] Detected push to main on ${remote_name} (${remote_url})." >&2
echo "[pre-push] Running local CI checks..." >&2

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

if [[ ! -x "$repo_root/scripts/ci_local.sh" ]]; then
  echo "[pre-push] Missing scripts/ci_local.sh; refusing to push." >&2
  exit 1
fi

"$repo_root/scripts/ci_local.sh"

echo "[pre-push] Local CI checks passed; continuing push." >&2
