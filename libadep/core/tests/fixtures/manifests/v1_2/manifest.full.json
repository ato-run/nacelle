{
  "schemaVersion": "1.2",
  "id": "00000000-0000-0000-0000-000000000031",
  "family_id": "00000000-0000-0000-0000-000000000040",
  "version": {
    "number": "0.3.1",
    "channel": "stable",
    "label": "full"
  },
  "network": {
    "egress_allow": [
      "https://cas.example.net"
    ],
    "egress_id_allow": [
      {
        "type": "spiffe",
        "value": "spiffe://example.net/deps/cas",
        "scheme": [
          "https"
        ],
        "ports": [
          443
        ],
        "trust": {
          "mode": "spiffe",
          "spiffe_id": "spiffe://example.net/deps/cas"
        }
      }
    ],
    "http_proxy_dev": true,
    "dev_resolver": "spire-lite"
  },
  "capabilities": [
    "network.fetch"
  ],
  "x-cas": {
    "index": "cas/index.json",
    "blobs": "cas/blobs/",
    "policy": {
      "trustDomain": "official",
      "verify": [
        "compressed",
        "raw"
      ]
    }
  },
  "dep_capsules": [
    "oci://ghcr.io/example/adep-deps@sha256:1111111111111111111111111111111111111111111111111111111111111111"
  ],
  "deps": {
    "python": {
      "requirements": "requirements.lock",
      "source": "cas://pypi/wheels",
      "install": {
        "mode": "offline",
        "target": ".venv",
        "no_deps": true
      }
    },
    "node": {
      "lockfile": "pnpm-lock.yaml",
      "store": "cas://pnpm",
      "install": {
        "mode": "offline",
        "frozen_lockfile": true
      }
    }
  },
  "files": [
    {
      "path": "dist/runtime.wasm",
      "sha256": "cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc",
      "size": 256,
      "role": "runtime"
    }
  ]
}